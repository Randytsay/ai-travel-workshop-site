---
const { title, platform, prompt, defaultOpen = false } = Astro.props;
---
<details class="prompt-card card" open={defaultOpen}>
  <summary>
    <span>
      <strong>{title}</strong>
      <small>{platform}</small>
    </span>
    <span class="summary-hint">展開</span>
  </summary>
  <pre>{prompt}</pre>
  <button class="btn copy-btn" type="button" data-text={prompt}>一鍵複製</button>
</details>
