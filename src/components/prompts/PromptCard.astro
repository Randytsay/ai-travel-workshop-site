---
const { title, platform, prompt } = Astro.props;
---
<div class="card">
  <p><strong>{title}</strong> <small>({platform})</small></p>
  <details>
    <summary>展開提示詞</summary>
    <pre style="white-space: pre-wrap;">{prompt}</pre>
  </details>
  <button class="btn copy-btn" data-text={prompt}>一鍵複製</button>
</div>
