---
import { navItems } from '../../content/navigation';
const { currentPath } = Astro.props;
const workshopQuickPaths = ['/doll-maker', '/travel-planner', '/notebooklm', '/sticker-lab', '/voting'];
const quick = workshopQuickPaths.map((path) => navItems.find((item) => item.path === path)).filter(Boolean);
---
<nav class="mobile-nav">
  {quick.map((item) => <a href={item?.path} style={currentPath === item?.path ? 'font-weight:700;color:#ff7f6a;' : ''}>{item?.short}</a>)}
</nav>
