  {navItems.map((item) => <a class={`nav-link ${currentPath === item.path ? 'active' : ''}`} href={item.path}>{item.label}</a>)}
  <div class="nav-meta">
    <strong>現場模式</strong>
    <p style="margin:8px 0 0;">依序完成公仔、旅遊需求、NotebookLM 研究與貼圖素材。</p>
  </div>
</aside>
