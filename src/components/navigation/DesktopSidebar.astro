---
import { navItems } from '../../content/navigation';
const { currentPath } = Astro.props;
---
<aside class="sidebar">
  <h3>AI 旅遊規劃師</h3>
  {navItems.map((item) => <a class={`nav-link ${currentPath === item.path ? 'active' : ''}`} href={item.path}>{item.label}</a>)}
  <div class="card" style="margin-top:12px;">
    <strong>Phase 1</strong>
    <p style="margin:8px 0 0;">已建立可擴充 MVP 骨架</p>
  </div>
</aside>
