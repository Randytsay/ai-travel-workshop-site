---
const { 
  title, 
  text, 
  primaryLabel, 
  primaryHref, 
  primaryExternal = false,
  secondaryLabel, 
  secondaryHref,
  secondaryExternal = false
} = Astro.props;
---
<section class="cta-band">
  <div>
    <p class="eyebrow">下一步</p>
    <h2>{title}</h2>
    <p>{text}</p>
  </div>
  <div class="actions">
    {primaryLabel && primaryHref && (
      <a class="btn" href={primaryHref} target={primaryExternal ? "_blank" : undefined} rel={primaryExternal ? "noreferrer" : undefined}>{primaryLabel}</a>
    )}
    {secondaryLabel && secondaryHref && (
      <a class="btn alt" href={secondaryHref} target={secondaryExternal ? "_blank" : undefined} rel={secondaryExternal ? "noreferrer" : undefined}>{secondaryLabel}</a>
    )}
  </div>
</section>
