---
import { progressTasks } from '../../content/progressTasks';
const total = progressTasks.length;
---
<div class="progress-tracker" id="progress-tracker">
  <div class="progress-bar-bg">
    <div class="progress-bar-fill" id="progress-fill" style="width: 0%"></div>
  </div>
  <p class="progress-text" id="progress-text-container">
    <span class="progress-count" id="progress-count">0</span> / <span id="progress-total">{total}</span> 已完成
  </p>
  <p class="progress-celebration" id="progress-celebration" hidden>太棒了，今天的工作坊任務全完成！</p>
</div>

<style>
  .progress-tracker {
    padding: 12px;
    background: #fff;
    border: 1px solid var(--line);
    border-radius: 12px;
    margin-bottom: 12px;
    box-shadow: var(--shadow-soft);
  }
  .progress-bar-bg {
    height: 8px;
    background: #f0f4f8;
    border-radius: 4px;
    overflow: hidden;
    margin-bottom: 6px;
  }
  .progress-bar-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--sky), var(--teal));
    transition: width 0.4s ease-out;
  }
  .progress-text {
    margin: 0;
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--ink-soft);
    text-align: right;
  }
  .progress-count {
    color: var(--coral);
  }
  .progress-celebration {
    margin: 6px 0 0;
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--teal);
    text-align: center;
    animation: fadeIn 0.5s ease-out;
  }
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(-4px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>

<script>
  import { getProgress } from '../../utils/progressStore';
  import { progressTasks } from '../../content/progressTasks';

  const updateUI = () => {
    const progress = getProgress();
    const count = progress.length;
    const total = progressTasks.length;
    const percentage = (count / total) * 100;

    const fill = document.getElementById('progress-fill') as HTMLElement;
    const countText = document.getElementById('progress-count') as HTMLElement;
    const textContainer = document.getElementById('progress-text-container') as HTMLElement;
    const celebration = document.getElementById('progress-celebration') as HTMLElement;

    if (fill) fill.style.width = `${percentage}%`;
    if (countText) countText.textContent = String(count);

    if (count === total && total > 0) {
      if (textContainer) textContainer.hidden = true;
      if (celebration) celebration.hidden = false;
    } else {
      if (textContainer) textContainer.hidden = false;
      if (celebration) celebration.hidden = true;
    }
  };

  // Initial update
  updateUI();

  // Listen for updates
  window.addEventListener('progress-update', updateUI);
</script>
