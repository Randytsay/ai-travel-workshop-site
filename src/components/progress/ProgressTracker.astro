---
import { progressTasks } from '../../content/progressTasks';
const total = progressTasks.length;
---
<div class="progress-tracker" id="progress-tracker">
  <div class="progress-bar-bg">
    <div class="progress-bar-fill" id="progress-fill" style="width: 0%"></div>
  </div>
  <p class="progress-text">
    <span class="progress-count" id="progress-count">0</span> / {total} 已完成
  </p>
</div>

<style>
  .progress-tracker {
    padding: 12px;
    background: #fff;
    border: 1px solid var(--line);
    border-radius: 12px;
    margin-bottom: 12px;
    box-shadow: var(--shadow-soft);
  }
  .progress-bar-bg {
    height: 8px;
    background: #f0f4f8;
    border-radius: 4px;
    overflow: hidden;
    margin-bottom: 6px;
  }
  .progress-bar-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--sky), var(--teal));
    transition: width 0.4s ease-out;
  }
  .progress-text {
    margin: 0;
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--ink-soft);
    text-align: right;
  }
  .progress-count {
    color: var(--coral);
  }
</style>

<script>
  import { getProgress } from '../../utils/progressStore';
  import { progressTasks } from '../../content/progressTasks';

  const updateUI = () => {
    const progress = getProgress();
    const count = progress.length;
    const total = progressTasks.length;
    const percentage = (count / total) * 100;

    const fill = document.getElementById('progress-fill');
    const text = document.getElementById('progress-count');

    if (fill) fill.style.width = `${percentage}%`;
    if (text) text.textContent = String(count);
  };

  // Initial update
  updateUI();

  // Listen for updates
  window.addEventListener('progress-update', updateUI);
</script>
