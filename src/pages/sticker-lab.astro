---
import WorkshopLayout from '../layouts/WorkshopLayout.astro';
import StepCard from '../components/common/StepCard.astro';
import StylePackCard from '../components/common/StylePackCard.astro';
import { stickerLabContent } from '../content/phase2Content';
---
<WorkshopLayout title="LINE 貼圖工坊" currentPath="/sticker-lab">
  <section class="card"><h1>{stickerLabContent.title}</h1><p>{stickerLabContent.subtitle}</p></section>
  <section class="card"><h2>成果層級</h2>{stickerLabContent.levels.map((l)=><p><strong>{l[0]}：</strong>{l[1]}</p>)}</section>
  {stickerLabContent.packs.map((pack)=><StylePackCard pack={pack} />)}
  <section class="card"><h2>LINE 拍貼 6 步驟</h2>{stickerLabContent.lineSteps.map((s,i)=><StepCard index={i+1} text={s} />)}</section>
  <section class="card"><a class="btn" href="#">上傳群組參加人氣票選</a> <a class="btn" href="/voting">前往現場投票頁</a></section>
</WorkshopLayout>
