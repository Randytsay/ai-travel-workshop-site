---
import WorkshopLayout from '../layouts/WorkshopLayout.astro';
import GalleryGrid from '../components/gallery/GalleryGrid.astro';
import GalleryModal from '../components/gallery/GalleryModal.astro';
import { galleryFilters, galleryItems } from '../data/gallery';
---
<WorkshopLayout title="成果牆" currentPath="/gallery">
  <section class="hero">
    <p class="eyebrow">Workshop Showcase</p>
    <h1>成果牆 Gallery</h1>
    <p>看看大家今天完成的公仔、貼圖與旅遊規劃成果，這裡會逐步變成每場工作坊的共創作品牆。</p>
  </section>
  <section class="card">
    <h2>篩選作品類型</h2>
    <div class="actions">{galleryFilters.map((f) => <button class="btn alt filter-btn" data-filter={f.key}>{f.label}</button>)}</div>
  </section>
  <section id="gallery-wrap" class="gallery-wall">{galleryItems.map((item) => <div data-item-type={item.type} data-title={item.title} data-desc={item.desc}><GalleryGrid items={[item]} /></div>)}</section>
  <GalleryModal />
  <section class="card notice"><h2>成果來源說明</h2><p>目前為 mock data 展示；後續將從學員授權提交素材同步至成果牆。</p><p><strong>TODO:</strong> 後續串接 Google Drive / Apps Script 資料源。</p></section>
  <a class="btn" href="/survey">前往問卷領講義</a>
</WorkshopLayout>
<script>
  const filters = document.querySelectorAll('.filter-btn');
  const items = document.querySelectorAll('[data-item-type]');
  const modal = document.getElementById('gallery-modal');
  filters.forEach((btn) => btn.addEventListener('click', () => {
    const key = btn.dataset.filter;
    items.forEach((item) => (item.style.display = key === 'all' || item.dataset.itemType === key ? 'block' : 'none'));
  }));
  document.querySelectorAll('[data-gallery-trigger]').forEach((card) =>
    card.addEventListener('click', () => {
      const p = card.closest('[data-title]');
      document.getElementById('gm-title').textContent = p?.dataset.title || '';
      document.getElementById('gm-desc').textContent = p?.dataset.desc || '';
      document.getElementById('gm-type').textContent = card.getAttribute('data-type-label') || '';
      document.getElementById('gm-owner').textContent = `作者：${card.getAttribute('data-owner') || ''}`;
      document.getElementById('gm-preview').textContent = card.querySelector('.emoji')?.textContent || '🖼️';
      modal?.showModal();
    })
  );
</script>
