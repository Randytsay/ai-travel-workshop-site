---
import WorkshopLayout from '../layouts/WorkshopLayout.astro';
import StepCard from '../components/common/StepCard.astro';
import CTASection from '../components/common/CTASection.astro';
import AssetPlaceholder from '../components/common/AssetPlaceholder.astro';
import PromptGroup from '../components/prompts/PromptGroup.astro';
import CompleteTaskButton from '../components/progress/CompleteTaskButton.astro';
import { dollPrompts } from '../content/prompts';
import { dollSteps } from '../content/workshopPages';
import { siteConfig } from '../content/siteConfig';
---
<WorkshopLayout title="我的 3D 可愛公仔" currentPath="/doll-maker">
  <section class="hero">
    <div class="hero-home">
      <div>
        <p class="eyebrow">✨ 第一個 Wow Moment</p>
        <h1>把照片變成專屬 3D 可愛公仔</h1>
        <p>這一站的目標很單純：選一張照片、複製魔法咒語、生成一張可以立刻做為旅行明信片分享的 3D 公仔成果。</p>
        <div class="actions">
          <a class="btn" href="#prompts">挑選風格</a>
          <a class="btn alt" href="/travel-planner">完成後前往下一站</a>
        </div>
      </div>
      <div class="hero-mockups">
        <article class="hero-mockup-card" style="padding-bottom:20px; border-radius:12px;">
          <p class="eyebrow" style="background:#f3fbff; color:#35b7d4;">Before</p>
          <div style="background:#eee; height:120px; border-radius:8px; margin-bottom:8px; display:grid; place-items:center; color:#999;">你的原始照片</div>
          <p class="muted" style="margin:0;">生活照 / 寵物照</p>
        </article>
        <article class="hero-mockup-card" style="padding-bottom:20px; border-radius:12px;">
          <p class="eyebrow">After</p>
          <div style="background:linear-gradient(135deg, #ffb4b0, #70c6ff); height:120px; border-radius:8px; margin-bottom:8px; display:grid; place-items:center; color:#fff; font-weight:bold; text-shadow:0 2px 4px rgba(0,0,0,0.2);">✨ 3D 化 ✨</div>
          <p class="muted" style="margin:0;">精緻質感盲盒公仔</p>
        </article>
      </div>
    </div>
  </section>

  <section class="feature-grid">
    <article class="card postcard-card">
      <p class="eyebrow">📸 紀念品清單</p>
      <h2>一張專屬公仔圖</h2>
      <p>適合放進 LINE 群組、現場快閃秀與後續成果明信片牆。</p>
    </article>
    <article class="card notice-card">
      <p class="eyebrow">💡 免費額度提醒</p>
      <h2>先求有，再求精緻</h2>
      <p>第一次生成不完美很正常，優先用短指令修正表情、構圖與背景。</p>
    </article>
    <article class="card itinerary-card">
      <p class="eyebrow">🛟 備援路線</p>
      <h2>ChatGPT 卡住就切 Gemini</h2>
      <p>每張提示詞卡都為你準備了 Gemini 版本，行程不用因額度停下來。</p>
    </article>
  </section>

  <section class="section-heading">
    <p class="eyebrow">🛠️ 紀念品製作流程</p>
    <h2>照著 6 步走</h2>
  </section>
  <section class="step-grid">
    {dollSteps.map(([title, text, note], index) => <StepCard index={index + 1} title={title} text={text} note={note} />)}
  </section>

  <section id="prompts" class="section-heading">
    <p class="eyebrow">🏪 紀念品商店風格架</p>
    <h2>3 種公仔提示詞盲盒</h2>
  </section>
  {dollPrompts.map((item) => <PromptGroup title={item.title} description={item.description} prompts={item.prompts} />)}

  <section class="asset-grid" style="margin-top: 32px;">
    <AssetPlaceholder title="公仔成果展示櫥窗" text="建議放個人、親子、寵物各一張 before/after 或完成圖。" type="圖片" />
    <AssetPlaceholder title="照片上傳流程圖" text="放 ChatGPT 上傳照片與貼上提示詞的截圖。" type="圖片" />
    <AssetPlaceholder title="30-60 秒魔法實況" text="示範從上傳照片到下載圖片的完整短片。" type="影片" />
  </section>
  <CompleteTaskButton 
    taskId="doll-maker-complete" 
    buttonLabel="我已完成公仔圖"
    nextLabel="旅遊需求整理" 
    nextHref="/travel-planner"
    successMessage="太棒了！你已完成第一個 Wow Moment。記得把公仔圖下載下來喔！"
  />

  <CTASection
    title="完成後請先分享到 LINE 群組"
    text="還不用等到作品完美。先上傳，講師與助教才能挑選快閃展示，也方便後面投票。"
    primaryLabel="上傳到工作坊 LINE 群組"
    primaryHref={siteConfig.workshopGroupUrl}
    primaryExternal={true}
    secondaryLabel="前往下一關"
    secondaryHref="/travel-planner"
  />
  <p class="disclaimer-text">上傳作品代表同意於本次工作坊成果展示與現場票選使用；若不希望公開展示，請於上傳前告知講師或助教。</p>
</WorkshopLayout>
