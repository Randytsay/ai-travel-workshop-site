---
import WorkshopLayout from '../layouts/WorkshopLayout.astro';
import VoteWorkCard from '../components/voting/VoteWorkCard.astro';
import LeaderboardPanel from '../components/voting/LeaderboardPanel.astro';
import { voteTabs, voteWorks } from '../data/voting';
---
<WorkshopLayout title="現場互動投票" currentPath="/voting">
  <section class="hero">
    <p class="eyebrow">現場互動</p>
    <h1>現場人氣票選</h1>
    <p>選出你最喜歡的作品，給創作者一個掌聲。目前是可 demo 的本機互動版，正式版再串 Firebase Realtime Database。</p>
  </section>
  <section class="card"><h2>分類</h2><div class="actions">{voteTabs.map((t) => <button class="btn alt vote-tab" data-type={t.key}>{t.label}</button>)}</div></section>
  <section id="vote-list" class="tool-grid">{voteWorks.map((w) => <div data-work-type={w.type}><VoteWorkCard work={w} /></div>)}</section>
  <LeaderboardPanel works={voteWorks} />
  <section class="feature-grid">
    <article class="card"><h2>獎項說明</h2><ul><li>人氣王（總票數第一）</li><li>最佳創意獎（講師團票選）</li><li>最暖故事獎（主持人特選）</li></ul></article>
    <article class="card notice"><h2>主持人控制區（預留）</h2><p>正式版可加入開始投票、暫停投票、公布得獎者、重設場次。</p></article>
  </section>
  <section class="card"><p><strong>待串接：</strong>Firebase Realtime Database、裝置投票限制、即時排行榜刷新與投影模式。</p></section>
</WorkshopLayout>
<script>
  const tabs = document.querySelectorAll('.vote-tab');
  const cards = document.querySelectorAll('[data-work-type]');
  const list = document.querySelector('[data-leaderboard-list]');

  const voteState = Array.from(document.querySelectorAll('.vote-card')).map((card) => {
    const voteCountNode = card.querySelector('[data-vote-count]');
    return {
      id: card.getAttribute('data-work-id') || '',
      title: card.querySelector('h3')?.textContent || '',
      votes: Number(voteCountNode?.textContent || '0')
    };
  });

  const renderLeaderboard = () => {
    if (!list) return;
    const topFive = [...voteState].sort((a, b) => b.votes - a.votes).slice(0, 5);
    list.innerHTML = topFive
      .map((item, index) => {
        const rankClass = index < 3 ? `rank rank-${index + 1}` : 'rank';
        const rankLabel = index === 0 ? '👑 第 1 名' : `第 ${index + 1} 名`;
        return `<li class="${rankClass}" data-work-id="${item.id}"><span class="rank-label">${rankLabel}</span><span>${item.title}</span><strong>${item.votes} 票</strong></li>`;
      })
      .join('');
  };

  tabs.forEach((tab) => tab.addEventListener('click', () => {
    const type = tab.dataset.type;
    cards.forEach((card) => {
      card.style.display = type === 'all' || card.dataset.workType === type ? 'block' : 'none';
    });
  }));

  document.querySelectorAll('.vote-card').forEach((card) => {
    const button = card.querySelector('.vote-button');
    const count = card.querySelector('[data-vote-count]');
    const feedback = card.querySelector('[data-vote-feedback]');
    const workId = card.getAttribute('data-work-id');

    button?.addEventListener('click', () => {
      const nextVotes = Number(count?.textContent || '0') + 1;
      if (count) count.textContent = String(nextVotes);
      const target = voteState.find((item) => item.id === workId);
      if (target) target.votes = nextVotes;
      renderLeaderboard();
      button.textContent = '已投票';
      button.setAttribute('disabled', 'true');
      if (feedback) feedback.hidden = false;
    });
  });
</script>
