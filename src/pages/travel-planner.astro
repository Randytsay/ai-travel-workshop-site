---
import WorkshopLayout from '../layouts/WorkshopLayout.astro';
import PromptCard from '../components/prompts/PromptCard.astro';
import { travelPrompts } from '../content/phase2Content';
---
<WorkshopLayout title="AI 旅遊規劃師" currentPath="/travel-planner">
  <section class="card"><h1>{travelPrompts.title}</h1><p>{travelPrompts.subtitle}</p></section>
  <section class="card"><h2>三軌入口</h2><ol><li>開啟專屬 GPT（推薦）</li><li>GPT 額度不足時貼到一般 ChatGPT</li><li>ChatGPT 受限時改用 Gemini</li></ol>
  <p><a class="btn" target="_blank" href="https://chatgpt.com/g/g-6a0829f788b88191ac0643f6ee0d615d-ai-lu-you-gui-hua-shi-gong-zuo-fang-ban">開啟 AI 旅遊規劃師｜工作坊版</a></p></section>
  <PromptCard title="ChatGPT 備援提示詞" platform="ChatGPT" prompt={travelPrompts.chatgpt} />
  <PromptCard title="Gemini 備援提示詞" platform="Gemini" prompt={travelPrompts.gemini} />
  <section class="card"><a class="btn" href="/notebooklm">前往下一步：NotebookLM 研究升級</a></section>
</WorkshopLayout>
