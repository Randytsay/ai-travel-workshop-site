---
import WorkshopLayout from '../layouts/WorkshopLayout.astro';
import CTASection from '../components/common/CTASection.astro';
import AssetPlaceholder from '../components/common/AssetPlaceholder.astro';
import CompleteTaskButton from '../components/progress/CompleteTaskButton.astro';
import { surveyReasons, surveyRewards, lineSteps } from '../content/surveyPage';
import { siteConfig } from '../content/siteConfig';
---
<WorkshopLayout title="課後問卷與講義領取" currentPath="/survey">
  <section class="hero">
    <p class="eyebrow">🛍️ 歸國紀念與免稅店</p>
    <h1>感謝參與今天的 AI 旅行</h1>
    <p>最後一站，請完成旅客意見表（問卷），並加入 LINE 官方旅行管家。你會收到完整的數位旅遊手冊（網頁講義）與隨身版（PDF 重點），方便日後隨時出發。</p>
  </section>

  <section class="feature-grid survey-reward-grid">
    <article class="card"><h2>為什麼要填意見表</h2><ul class="example-list">{surveyReasons.map((r)=> <li>{r}</li>)}</ul></article>
    <article class="card survey-reward-card boarding-pass-card"><h2>🎁 歸國紀念禮包解鎖</h2><ul class="example-list">{surveyRewards.map((r)=> <li>{r}</li>)}</ul></article>
    <article class="card notice-card"><h2>🔑 通關密語提醒</h2><p>加入 LINE 官方旅行管家後，請輸入通關密語：<strong>「我要講義」</strong>。</p></article>
  </section>

  {siteConfig.featureFlags.enableCashbackBridgeCard && (
    <section class="card cashback-bridge-card">
      <p class="eyebrow">旅行消費小啟發</p>
      <h2>旅行花得多，回饋能不能慢慢累積？</h2>
      <p>一趟旅行花費不低，如果日常消費能逐步累積回饋，長期會是什麼感覺？這裡先不談產品，先從機制與思維開始理解。</p>
      <a class="btn" href={siteConfig.cashbackInterestUrl}>我想了解這個機制</a>
    </section>
  )}

  <section class="two-col" style="margin-top:24px;">
    <section class="card survey-entry-card" style="display:flex; flex-direction:column; justify-content:center; align-items:center; text-align:center;">
      <p class="eyebrow">📝 旅客意見表</p>
      <h2>前往填寫問卷</h2>
      <a class="btn" href={siteConfig.surveyUrl} target="_blank" rel="noreferrer" style="margin-top:16px;">前往課後問卷</a>
    </section>
    <section class="card line-task-card itinerary-card">
      <p class="eyebrow">📲 紀念品領取流程</p>
      <h2>「我要講義」三步驟</h2>
      <ol class="example-list" style="margin-bottom:16px;">{lineSteps.map((s)=> <li>{s}</li>)}</ol>
      <div class="actions" style="margin-top:auto;">
        <a class="btn ghost" href={siteConfig.officialLineUrl} target="_blank" rel="noreferrer">加入 LINE 官方管家</a>
        <a class="btn ghost" href={siteConfig.workshopGroupUrl} target="_blank" rel="noreferrer">工作坊旅行團 (LINE)</a>
      </div>
    </section>
  </section>

  <section class="asset-grid" style="margin-top: 32px;">
    <AssetPlaceholder title="旅客意見表 QR Code" text="正式活動前替換成問卷工具的 QR Code。" type="QR Code" />
    <AssetPlaceholder title="LINE 官方管家 QR Code" text="正式活動前替換成官方帳號加入 QR Code。" type="QR Code" />
    <AssetPlaceholder title="紀念品領取圖解" text="可放三步驟圖解或現場投影片同款圖。" type="圖片" />
  </section>

  <section class="card" style="margin-top:32px;">
    <p class="eyebrow">📖 手冊形式說明</p>
    <h2>主體是數位導覽，PDF 是隨身小冊</h2>
    <p>數位導覽（網頁）可保留一鍵複製提示詞、操作影片、更新版流程與成果明信片牆；隨身小冊（PDF）則適合快速回顧重點。</p>
  </section>

  <CompleteTaskButton 
    taskId="survey-complete" 
    buttonLabel="我已完成問卷與講義領取流程"
    successMessage="恭喜！你已完成所有流程，講義已在 LINE 等著你。"
  />

  <CTASection title="下段旅程見" text="課後可以依照網站導航重新操作一次，把今天的魔法變成自己的日常裝備。" primaryLabel="回到旅行入口 (首頁)" primaryHref="/" secondaryLabel="查看明信片牆" secondaryHref="/gallery" />
</WorkshopLayout>
