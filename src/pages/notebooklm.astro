---
import WorkshopLayout from '../layouts/WorkshopLayout.astro';
import StepCard from '../components/common/StepCard.astro';
import PromptCard from '../components/prompts/PromptCard.astro';
import { notebookContent } from '../content/phase2Content';
---
<WorkshopLayout title="NotebookLM 研究升級" currentPath="/notebooklm">
  <section class="card"><h1>{notebookContent.title}</h1><p>{notebookContent.subtitle}</p></section>
  {notebookContent.steps.map((s,i)=><StepCard index={i+1} text={s} />)}
  {notebookContent.prompts.map((p)=><PromptCard title={p.title} platform={p.platform} prompt={p.prompt} />)}
  <section class="card"><a class="btn" href="/sticker-lab">前往下一關：LINE 貼圖工坊</a></section>
</WorkshopLayout>
