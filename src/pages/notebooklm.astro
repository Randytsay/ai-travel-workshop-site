---
import WorkshopLayout from '../layouts/WorkshopLayout.astro';
import PromptCard from '../components/prompts/PromptCard.astro';
import { notebookContent } from '../content/prompts';
---
<WorkshopLayout title="NotebookLM 研究升級" currentPath="/notebooklm">
  <section class="card"><h1>讓 NotebookLM 接手旅遊研究</h1><p>貼入需求總表、轉為來源、執行 Deep Research、再追問產出最終方案。</p></section>
  {notebookContent.prompts.map((item) => <PromptCard title={item.title} platform="NotebookLM" prompt={item.prompts.chatgpt} />)}
</WorkshopLayout>
